{
  "name": "@gotgenes/pi-autoformat",
  "version": "4.0.5",
  "description": "Pi extension package for prompt-end auto-formatting",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "autoformat",
    "formatter",
    "prompt-end",
    "biome",
    "prettier",
    "typescript"
  ],
  "author": {
    "name": "Chris Lasher"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gotgenes/pi-autoformat"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:md": "markdownlint-cli2 --config ../../.markdownlint-cli2.yaml '*.md' 'docs/**/*.md'"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "catalog:",
    "markdownlint-cli2": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
